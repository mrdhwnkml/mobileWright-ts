{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2020",
    "types": ["node"],
    "moduleResolution": "NodeNext",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,

    "jsx": "react-jsx",

    "verbatimModuleSyntax": false,
    "isolatedModules": false,

    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
